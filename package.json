{
  "name": "EmployeeManagement",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.17.0",
    "mbt": "^1.2.49",
    "rimraf": "^5.0.5",
    "sqlite3": "^6.0.1"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-employeemanagement": "cds watch --open com.sap.em.employeemanagement/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy EmployeeManagement --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "cds": {
    "requires": {
      "db": {},
      "auth": {
        "[development]": {
          "kind": "mocked",
          "users": {
            "Chitti": {
              "name": "Chitti",
              "password": "user",
              "roles": [
                "EMPViewer"
              ]
            },
            "EMPAdmin": {
              "name": "EMPAdmin",
              "password": "user",
              "roles": [
                "EMPAdmin"
              ]
            },
            "EMPManager": {
              "name": "EMPManager",
              "password": "user",
              "roles": [
                "EMPManager"
              ]
            }
          }
        }
      },
      "[production]": {
        "auth": {
          "kind": "xsuaa"
        }
      }
    }
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/employeemanagement"
  ]
}
